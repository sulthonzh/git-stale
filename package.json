{
  "name": "git-stale",
  "version": "1.2.0",
  "description": "Find stale local git branches that are safe to delete",
  "bin": {
    "git-stale": "./cli.js"
  },
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./cli.js": "./cli.js"
  },
  "scripts": {
    "test": "node --test --test-timeout=120000 tests/*.test.mjs",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test --test-timeout=120000 tests/*.test.mjs",
    "lint": "eslint cli.js src/index.js tests/*.test.mjs",
    "stale": "node cli.js",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "git",
    "branches",
    "stale",
    "cleanup",
    "cli",
    "safe",
    "delete"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "cli.js",
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/git-stale"
  },
  "author": "sulthonzh",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0"
  }
}
